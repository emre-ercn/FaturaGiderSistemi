@model FaturaGiderSistemi.Models.Fatura

@{
    ViewData["Title"] = "Yeni Fatura Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Tasarımı garanti altına almak için Bootstrap'i zorla sayfaya dahil ediyoruz -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">
    <h2 class="mb-4">Yeni Fatura Ekle</h2>

    <!-- İŞTE BU KISIM BİZE GİZLİ HATALARI BAĞIRARAK SÖYLEYECEK -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mb-4 shadow-sm">
            <h5 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> Kayıt Başarısız!</h5>
            <hr>
            @Html.ValidationSummary(false, "", new { @class = "mb-0" })
        </div>
    }

    <div class="card shadow-sm p-4">
        <!-- asp-action yerine standart HTML form gönderimi kullanıyoruz -->
        <form action="/Fatura/Create" method="post">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="control-label fw-bold">Fatura No</label>
                    <input type="text" name="FaturaNo" class="form-control" placeholder="Örn: FAT-2026-001" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="control-label fw-bold">Fiş No</label>
                    <input type="text" name="FisNo" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="control-label fw-bold">Tarih</label>
                    <input type="date" name="Tarih" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="control-label fw-bold">Şirket</label>

                    <!-- Tag Helper yerine manuel C# döngüsü ile açılır menü oluşturuyoruz -->
                    <select name="SirketId" class="form-select" required>
                        <option value="">-- Şirket Seçiniz --</option>
                        @if (ViewBag.SirketlerListesi != null)
                        {
                            foreach (var sirket in ViewBag.SirketlerListesi)
                            {
                                <option value="@sirket.Value">@sirket.Text</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="control-label fw-bold">KDV Oranı (%)</label>
                    <input type="number" name="KdvOrani" class="form-control" value="20" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="control-label fw-bold">Toplam Tutar (TL)</label>
                    <input type="number" step="0.01" name="ToplamTutar" class="form-control" required />
                </div>
            </div>

            <div class="form-group form-check mb-4">
                <label class="form-check-label fw-bold">
                    <!-- Checkbox için standart HTML -->
                    <input type="checkbox" class="form-check-input" name="Durum" value="true" /> Ödendi mi?
                    <!-- Seçilmezse false gitmesi için gizli alan -->
                    <input type="hidden" name="Durum" value="false" />
                </label>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Kaydet</button>
                <a href="/Fatura/Index" class="btn btn-secondary ms-2">Listeye Dön</a>
            </div>

        </form>
    </div>
</div>