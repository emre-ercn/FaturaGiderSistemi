@model FaturaGiderSistemi.Models.Fatura

@{
    ViewData["Title"] = "Yeni Fatura Ekle";
}

<h1 class="mt-4">Yeni Fatura Ekle</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="FaturaNo" class="control-label fw-bold"></label>
                <input asp-for="FaturaNo" class="form-control" placeholder="Örn: FAT-2026-001" />
                <span asp-validation-for="FaturaNo" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="FisNo" class="control-label fw-bold"></label>
                <input asp-for="FisNo" class="form-control" />
                <span asp-validation-for="FisNo" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 form-group mb-3">
                    <label asp-for="Tutar" class="control-label fw-bold"></label>
                    <input asp-for="Tutar" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Tutar" class="text-danger"></span>
                </div>
                <div class="col-md-4 form-group mb-3">
                    <label asp-for="KdvOrani" class="control-label fw-bold"></label>
                    <input asp-for="KdvOrani" class="form-control" type="number" placeholder="%18" />
                    <span asp-validation-for="KdvOrani" class="text-danger"></span>
                </div>
                <div class="col-md-4 form-group mb-3">
                    <label asp-for="ToplamTutar" class="control-label fw-bold"></label>
                    <input asp-for="ToplamTutar" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="ToplamTutar" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Tarih" class="control-label fw-bold"></label>
                <input asp-for="Tarih" class="form-control" type="date" />
                <span asp-validation-for="Tarih" class="text-danger"></span>
            </div>

            <!-- İŞTE BİZİM AÇILIR MENÜLERİMİZ (DROPDOWN) -->
            <div class="form-group mb-3">
                <label asp-for="SirketId" class="control-label fw-bold"></label>
                <select asp-for="SirketId" class="form-select" asp-items="ViewBag.SirketId">
                    <option value="">-- Lütfen Şirket Seçiniz --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="KullaniciId" class="control-label fw-bold"></label>
                <select asp-for="KullaniciId" class="form-select" asp-items="ViewBag.KullaniciId">
                    <option value="">-- Lütfen Kullanıcı Seçiniz --</option>
                </select>
            </div>

            <div class="form-group form-check mb-4 mt-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Durum" />
                    <strong>@Html.DisplayNameFor(model => model.Durum) (Ödendi mi?)</strong>
                </label>
            </div>

            <div class="form-group d-grid gap-2 d-md-block">
                <input type="submit" value="Kaydet" class="btn btn-success px-4" />
                <a asp-action="Index" class="btn btn-secondary px-4">Listeye Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}