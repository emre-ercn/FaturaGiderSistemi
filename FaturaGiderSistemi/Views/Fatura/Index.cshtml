@model IEnumerable<FaturaGiderSistemi.Models.Fatura>

@{
    ViewData["Title"] = "Fatura Listesi";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h1 class="text-primary">Fatura Listesi</h1>
    <a asp-action="Create" class="btn btn-success fw-bold shadow-sm">+ Yeni Fatura Ekle</a>
</div>
<hr />

<!-- Arama Çubuğu Başlangıcı -->
<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group shadow-sm">
        <input type="text" name="aramaKelimesi" class="form-control" placeholder="Fatura numarası girin..." value="@ViewData["CurrentFilter"]" />
        <button type="submit" class="btn btn-primary fw-bold px-4">Ara</button>
        <a asp-action="Index" class="btn btn-outline-secondary px-4">Temizle</a>
    </div>
</form>
<!-- Arama Çubuğu Bitişi -->

<div class="table-responsive shadow-sm rounded">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.FaturaNo)</th>
                <th>Şirket</th>
                <th>@Html.DisplayNameFor(model => model.Tarih)</th>
                <th>Tutar</th>
                <th>KDV</th>
                <th>Toplam</th>
                <th>Durum</th>
                <th class="text-center">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@Html.DisplayFor(modelItem => item.FaturaNo)</td>

                    <!-- İŞTE SİHİRLİ SATIR BURASI: Artık 2 yerine şirket ismi yazacak -->
                    <td class="fw-bold text-secondary">@Html.DisplayFor(modelItem => item.Sirket.Ad)</td>

                    <td>@item.Tarih.ToShortDateString()</td>
                    <td>@item.Tutar.ToString("N2") ₺</td>
                    <td>%@item.KdvOrani</td>
                    <td class="text-success fw-bold">@item.ToplamTutar.ToString("N2") ₺</td>
                    <td>
                        @if (item.Durum)
                        {
                            <span class="badge bg-success px-2 py-1">Ödendi</span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-2 py-1">Ödenmedi</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Detay</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>