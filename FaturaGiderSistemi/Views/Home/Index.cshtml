@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold">Yönetim Paneli</h2>

    <div class="row">
      
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-primary shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Toplam Fatura</h5>
                    <h2 class="display-5 fw-bold">@ViewBag.ToplamFaturaSayisi</h2>
                    <p class="card-text">Sistemdeki kayıtlı evrak</p>
                </div>
            </div>
        </div>

        
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-info shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Kayıtlı Şirket</h5>
                    <h2 class="display-5 fw-bold">@ViewBag.ToplamSirketSayisi</h2>
                    <p class="card-text">Çalışılan kurum sayısı</p>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-white bg-success shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Ödenen Toplam</h5>
                    <h2 class="display-6 fw-bold">@ViewBag.ToplamOdenen.ToString("N2") ₺</h2>
                    <p class="card-text">Tahsilatı tamamlanan</p>
                </div>
            </div>
        </div>

        
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-danger shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Bekleyen Ödemeler</h5>
                    <h2 class="display-6 fw-bold">@ViewBag.ToplamBekleyen.ToString("N2") ₺</h2>
                    <p class="card-text">Tahsilat bekleyen</p>
                </div>
            </div>
        </div>
    </div>
</div>