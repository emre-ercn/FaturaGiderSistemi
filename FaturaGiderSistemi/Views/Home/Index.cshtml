@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-4">
    <h2 class="mb-4 fw-bold">Yönetim Paneli</h2>

    <div class="row">
        <!-- Toplam Fatura Kartı -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-primary shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Toplam Fatura</h5>
                    <h2 class="display-5 fw-bold">@ViewBag.ToplamFaturaSayisi</h2>
                    <p class="card-text">Sistemdeki kayıtlı evrak</p>
                </div>
            </div>
        </div>

        <!-- Kayıtlı Şirket Kartı -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-info shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Kayıtlı Şirket</h5>
                    <h2 class="display-5 fw-bold">@ViewBag.ToplamSirketSayisi</h2>
                    <p class="card-text">Çalışılan kurum sayısı</p>
                </div>
            </div>
        </div>

        <!-- Ödenen Tutar Kartı -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-success shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Ödenen Toplam</h5>
                    <h2 class="display-6 fw-bold">@ViewBag.ToplamOdenen.ToString("N2") ₺</h2>
                    <p class="card-text">Tahsilatı tamamlanan</p>
                </div>
            </div>
        </div>

        <!-- Bekleyen Tutar Kartı -->
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-danger shadow h-100">
                <div class="card-body">
                    <h5 class="card-title">Bekleyen Ödemeler</h5>
                    <h2 class="display-6 fw-bold">@ViewBag.ToplamBekleyen.ToString("N2") ₺</h2>
                    <p class="card-text">Tahsilat bekleyen</p>
                </div>
            </div>
        </div>
    </div>

    <!-- GRAFİK ALANI -->
    <div class="row mt-4">
        <div class="col-md-6 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-pie-chart-fill"></i> Ödeme Durumu Dağılımı
                </div>
                <div class="card-body">
                    <!-- Grafiğin çizileceği tuval (canvas) -->
                    <canvas id="faturaGrafigi" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js Kütüphanesini Çağırıyoruz -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        var ctx = document.getElementById('faturaGrafigi').getContext('2d');
        var faturaGrafigi = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Ödenen (₺)', 'Bekleyen (₺)'],
                datasets: [{
                    data: [
                        @ViewBag.ToplamOdenen.ToString().Replace(",", "."),
                        @ViewBag.ToplamBekleyen.ToString().Replace(",", ".")
                    ],
                    backgroundColor: [
                        '#198754', // Yeşil (Ödenen)
                        '#dc3545'  // Kırmızı (Bekleyen)
                    ],
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>
}